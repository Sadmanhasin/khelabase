// Khelabase — Bangladesh's Football Ecosystem
// Prisma schema. Core domains: identity, community, teams, tournaments,
// matches, statistics, venues, notifications. Marketplace/chat land in later phases.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Gender {
  MALE
  FEMALE
  MIXED
}

enum FootballFormat {
  F5
  F6
  F7
  F8
  F11
}

enum PlayerPosition {
  GOALKEEPER
  DEFENDER
  MIDFIELDER
  FORWARD
}

enum PreferredFoot {
  LEFT
  RIGHT
  BOTH
}

enum ExperienceLevel {
  BEGINNER
  AMATEUR
  SEMI_PRO
  PRO
}

enum TeamType {
  SOCIAL
  ACADEMY
  CLUB
}

enum TeamRole {
  OWNER
  MANAGER
  CAPTAIN
  COACH
  ASSISTANT
  PLAYER
}

enum MembershipStatus {
  ACTIVE
  PENDING
  INVITED
  LEFT
  REMOVED
}

enum TournamentType {
  KNOCKOUT
  LEAGUE
  LEAGUE_KNOCKOUT
  GROUP_STAGE
  DOUBLE_ELIMINATION
  FRIENDLY
  CUSTOM
}

enum AgeCategory {
  OPEN
  U14
  U16
  U18
  U21
  VETERANS
}

enum Visibility {
  PUBLIC
  PRIVATE
  INVITE_ONLY
}

enum TournamentStatus {
  DRAFT
  PENDING_APPROVAL
  REGISTRATION_OPEN
  ONGOING
  COMPLETED
  CANCELLED
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  HALFTIME
  COMPLETED
  POSTPONED
  CANCELLED
}

enum MatchEventType {
  GOAL
  ASSIST
  YELLOW_CARD
  RED_CARD
  SUBSTITUTION
  INJURY
  PENALTY
  OWN_GOAL
  CORNER
  OFFSIDE
  SHOOTOUT_GOAL
  SHOOTOUT_MISS
}

enum FollowTargetType {
  USER
  PLAYER
  TEAM
  ORGANIZER
  TOURNAMENT
  VENUE
}

enum NotificationType {
  SYSTEM
  FOLLOW
  TEAM_INVITE
  JOIN_REQUEST
  TOURNAMENT
  MATCH
  AWARD
  TRANSFER
  CHAT
  MARKETPLACE
}

enum PostType {
  TEXT
  PHOTO
  VIDEO
  ACHIEVEMENT
  TOURNAMENT_UPDATE
  MATCH_RESULT
  TRANSFER
  AWARD
}

enum AwardType {
  TOP_SCORER
  BEST_GOALKEEPER
  GOLDEN_BALL
  BEST_DEFENDER
  BEST_MIDFIELDER
  MOST_ASSISTS
  FAIR_PLAY
  MVP
  CUSTOM
}

enum ProductCategory {
  JERSEY
  BOOTS
  FOOTBALL
  GLOVES
  TRAINING
  ACCESSORY
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────
// Auth.js (NextAuth) tables
// ─────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Identity
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  coverImage    String?
  bio           String?
  district      String?
  dateOfBirth   DateTime?
  gender        Gender?
  phone         String?
  socialLinks   Json?
  isVerified    Boolean   @default(false)
  isAdmin       Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  playerProfile   PlayerProfile?
  organizerProfiles OrganizerProfile[]
  ownedVenues     Venue[]
  teamMemberships TeamMember[]
  posts           Post[]
  comments        Comment[]
  postLikes       PostLike[]
  savedPosts      SavedPost[]
  following       Follow[]         @relation("Follower")
  notifications   Notification[]   @relation("Recipient")
  actorNotifications Notification[] @relation("Actor")
  products        Product[]
  cartItems       CartItem[]
  orders          Order[]

  @@index([district])
}

model PlayerProfile {
  id               String           @id @default(cuid())
  userId           String           @unique
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredPosition PlayerPosition?
  secondaryPosition PlayerPosition?
  preferredFoot    PreferredFoot?
  heightCm         Int?
  jerseyNumber     Int?
  playingStyle     String?
  experienceLevel  ExperienceLevel?
  availabilityStatus String?
  lookingForTeam   Boolean          @default(false)
  currentTeamId    String?
  currentTeam      Team?            @relation("CurrentTeam", fields: [currentTeamId], references: [id])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  matchStats   PlayerMatchStat[]
  awards       Award[]
  achievements Achievement[]
}

// ─────────────────────────────────────────────────────────────
// Teams
// ─────────────────────────────────────────────────────────────

model Team {
  id          String         @id @default(cuid())
  name        String
  shortName   String?
  slug        String         @unique
  logo        String?
  coverImage  String?
  description String?
  district    String?
  foundedDate DateTime?
  format      FootballFormat @default(F11)
  type        TeamType       @default(SOCIAL)
  isVerified  Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  members          TeamMember[]
  currentPlayers   PlayerProfile[]    @relation("CurrentTeam")
  homeMatches      Match[]            @relation("HomeTeam")
  awayMatches      Match[]            @relation("AwayTeam")
  tournamentEntries TournamentTeam[]
  standings        Standing[]
  achievements     Achievement[]

  @@index([district])
}

model TeamMember {
  id           String           @id @default(cuid())
  teamId       String
  team         Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId       String
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  role         TeamRole         @default(PLAYER)
  jerseyNumber Int?
  status       MembershipStatus @default(ACTIVE)
  joinedAt     DateTime         @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

// ─────────────────────────────────────────────────────────────
// Organizers & Venues
// ─────────────────────────────────────────────────────────────

model OrganizerProfile {
  id          String       @id @default(cuid())
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String
  slug        String       @unique
  logo        String?
  coverImage  String?
  description String?
  district    String?
  contact     String?
  socialLinks Json?
  isVerified  Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tournaments Tournament[]
}

model Venue {
  id          String   @id @default(cuid())
  ownerId     String?
  owner       User?    @relation(fields: [ownerId], references: [id])
  name        String
  slug        String   @unique
  logo        String?
  coverImage  String?
  description String?
  district    String?
  address     String?
  latitude    Float?
  longitude   Float?
  facilities  Json?
  formats     FootballFormat[]
  rating      Float?   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  matches     Match[]
  tournaments Tournament[]
}

// ─────────────────────────────────────────────────────────────
// Tournaments
// ─────────────────────────────────────────────────────────────

model Tournament {
  id                  String           @id @default(cuid())
  name                String
  slug                String           @unique
  logo                String?
  banner              String?
  description         String?
  rules               String?
  organizerId         String
  organizer           OrganizerProfile @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  venueId             String?
  venue               Venue?           @relation(fields: [venueId], references: [id])
  location            String?
  format              FootballFormat   @default(F11)
  type                TournamentType   @default(KNOCKOUT)
  ageCategory         AgeCategory      @default(OPEN)
  gender              Gender           @default(MALE)
  visibility          Visibility       @default(PUBLIC)
  status              TournamentStatus @default(DRAFT)
  season              String?
  registrationDeadline DateTime?
  startDate           DateTime?
  endDate             DateTime?
  entryFee            Int?             @default(0)
  prizeMoney          Int?             @default(0)
  isPaidRegistration  Boolean          @default(false)
  maxTeams            Int?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  teams     TournamentTeam[]
  matches   Match[]
  standings Standing[]
  awards    Award[]

  @@index([status])
  @@index([format])
}

model TournamentTeam {
  id           String             @id @default(cuid())
  tournamentId String
  tournament   Tournament         @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  status       RegistrationStatus @default(PENDING)
  paymentRef   String?
  groupName    String?
  seed         Int?
  registeredAt DateTime           @default(now())

  @@unique([tournamentId, teamId])
}

// ─────────────────────────────────────────────────────────────
// Matches & Statistics
// ─────────────────────────────────────────────────────────────

model Match {
  id           String      @id @default(cuid())
  tournamentId String?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  round        String?
  homeTeamId   String
  homeTeam     Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId   String
  awayTeam     Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  venueId      String?
  venue        Venue?      @relation(fields: [venueId], references: [id])
  kickoff      DateTime?
  durationMin  Int?        @default(90)
  status       MatchStatus @default(SCHEDULED)
  homeScore    Int         @default(0)
  awayScore    Int         @default(0)
  homeShootout Int?
  awayShootout Int?
  isFriendly   Boolean     @default(false)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  events     MatchEvent[]
  playerStats PlayerMatchStat[]

  @@index([status])
  @@index([kickoff])
}

model MatchEvent {
  id        String         @id @default(cuid())
  matchId   String
  match     Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  type      MatchEventType
  minute    Int?
  teamId    String?
  playerId  String?
  playerName String?
  relatedPlayerId String?
  note      String?
  createdAt DateTime       @default(now())

  @@index([matchId])
}

model PlayerMatchStat {
  id         String        @id @default(cuid())
  matchId    String
  match      Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId   String
  player     PlayerProfile @relation(fields: [playerId], references: [id], onDelete: Cascade)
  goals      Int           @default(0)
  assists    Int           @default(0)
  yellowCards Int          @default(0)
  redCards   Int           @default(0)
  ownGoals   Int           @default(0)
  minutes    Int           @default(0)
  cleanSheet Boolean       @default(false)
  isMvp      Boolean       @default(false)

  @@unique([matchId, playerId])
}

model Standing {
  id           String     @id @default(cuid())
  tournamentId String
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  groupName    String?
  played       Int        @default(0)
  won          Int        @default(0)
  drawn        Int        @default(0)
  lost         Int        @default(0)
  goalsFor     Int        @default(0)
  goalsAgainst Int        @default(0)
  points       Int        @default(0)

  @@unique([tournamentId, teamId])
}

model Award {
  id           String        @id @default(cuid())
  tournamentId String?
  tournament   Tournament?   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  playerId     String?
  player       PlayerProfile? @relation(fields: [playerId], references: [id])
  type         AwardType
  title        String
  createdAt    DateTime      @default(now())
}

model Achievement {
  id        String         @id @default(cuid())
  playerId  String?
  player    PlayerProfile? @relation(fields: [playerId], references: [id], onDelete: Cascade)
  teamId    String?
  team      Team?          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  title     String
  detail    String?
  icon      String?
  occurredAt DateTime      @default(now())
}

// ─────────────────────────────────────────────────────────────
// Community: posts, follows, notifications
// ─────────────────────────────────────────────────────────────

model Post {
  id        String     @id @default(cuid())
  authorId  String
  author    User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  type      PostType   @default(TEXT)
  content   String?
  mediaUrls String[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  comments Comment[]
  likes    PostLike[]
  saves    SavedPost[]

  @@index([authorId])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
}

model PostLike {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model SavedPost {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Follow {
  id         String           @id @default(cuid())
  followerId String
  follower   User             @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  targetType FollowTargetType
  targetId   String
  createdAt  DateTime         @default(now())

  @@unique([followerId, targetType, targetId])
  @@index([targetType, targetId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation("Recipient", fields: [userId], references: [id], onDelete: Cascade)
  actorId   String?
  actor     User?            @relation("Actor", fields: [actorId], references: [id])
  type      NotificationType @default(SYSTEM)
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}

// ─────────────────────────────────────────────────────────────
// Marketplace
// ─────────────────────────────────────────────────────────────

model Product {
  id          String          @id @default(cuid())
  sellerId    String
  seller      User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  name        String
  slug        String          @unique
  description String?
  category    ProductCategory
  price       Int             // in BDT (whole taka)
  stock       Int             @default(0)
  images      String[]
  brand       String?
  rating      Float?          @default(0)
  isActive    Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@index([category])
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  @@unique([userId, productId])
}

model Order {
  id        String      @id @default(cuid())
  buyerId   String
  buyer     User        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  total     Int
  status    OrderStatus @default(PENDING)
  address   String?
  phone     String?
  createdAt DateTime    @default(now())

  items OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  price     Int
  quantity  Int     @default(1)
}
